DATABASE_URL="file:./dev.db"
UPLOAD_DIR="./uploads"

# Public URL for password reset links.
APP_BASE_URL="http://localhost:3000"

# Optional SMTP for password reset emails.
# SMTP_HOST=""
# SMTP_PORT="587"
# SMTP_SECURE="false"
# SMTP_USER=""
# SMTP_PASS=""
# SMTP_FROM="TMS <no-reply@example.com>"

# Set to "false" when the app is served over plain HTTP (no TLS).
# Leave unset on HTTPS production so secure session cookies are enabled.
# COOKIE_SECURE="false"

# Required for customer business search and location address autocomplete (Google Places API).
# Enable "Places API (New)" in Google Cloud for the project tied to this key.
# https://console.cloud.google.com/apis/library/places.googleapis.com
GOOGLE_PLACES_API_KEY=""

# Required for MC/DOT carrier lookup autocomplete (FMCSA QCMobile API).
# Create a free webKey at https://mobile.fmcsa.dot.gov/QCDevsite/
FMCSA_WEB_KEY=""
