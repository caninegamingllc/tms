DATABASE_URL="file:./dev.db"
UPLOAD_DIR="./uploads"

# Set to "false" when the app is served over plain HTTP (no TLS).
# Leave unset on HTTPS production so secure session cookies are enabled.
# COOKIE_SECURE="false"

# Required for customer business search autocomplete (Google Places API).
# Enable Places API (New) in Google Cloud and restrict the key to server-side use.
GOOGLE_PLACES_API_KEY=""
