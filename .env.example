DATABASE_URL="postgresql://tms:tms@localhost:5432/tms?schema=public"
# Optional pooled URL for the app (PgBouncer / Neon pooler). Migrations use DATABASE_URL.
# DATABASE_POOL_URL="postgresql://tms:tms@localhost:5432/tms?schema=public&pgbouncer=true"
# Optional distinct URL for `prisma migrate deploy` when the app uses a pooler.
# DATABASE_MIGRATE_URL="postgresql://tms:tms@localhost:5432/tms?schema=public"

# Local disk fallback when S3_* is unset. Prefer object storage in production.
UPLOAD_DIR="./uploads"

# S3-compatible object storage (Cloudflare R2, AWS S3, MinIO, DigitalOcean Spaces).
# When set, documents and logos are stored as objects instead of local disk.
# S3_BUCKET="tms-uploads"
# S3_ACCESS_KEY_ID=""
# S3_SECRET_ACCESS_KEY=""
# S3_REGION="auto"
# S3_ENDPOINT="https://xxxxxxxx.r2.cloudflarestorage.com"
# Optional key prefix within the bucket:
# S3_PREFIX="prod"

# Redis for shared rate limits / cache across app instances (optional; falls back to in-memory).
# REDIS_URL="redis://localhost:6379"

# Background job worker poll interval (ms).
# JOB_WORKER_POLL_MS="2000"

# Public URL of this deployment (required in production).
# Used for password-reset links, invites, Stripe, and OAuth redirects when
# provider-specific *_REDIRECT_URI vars are unset.
APP_BASE_URL="http://localhost:3000"

# Password reset email via Resend (recommended).
# Use a sender on a domain verified in Resend.
RESEND_API_KEY=""
RESEND_FROM="TMS <no-reply@yourdomain.com>"

# Optional Resend SMTP fallback (same API key as RESEND_API_KEY).
# SMTP_HOST="smtp.resend.com"
# SMTP_PORT="587"
# SMTP_USER="resend"
# SMTP_PASS=""
# SMTP_FROM="TMS <no-reply@yourdomain.com>"  # required when using SMTP_* (verified Resend domain)

# Set to "false" when the app is served over plain HTTP (no TLS).
# Leave unset on HTTPS production so secure session cookies are enabled.
# COOKIE_SECURE="false"

# Required for customer business search, location address autocomplete, load route geocoding, and routing.
# Enable these APIs in Google Cloud for the project tied to this key:
# - Places API (New): https://console.cloud.google.com/apis/library/places.googleapis.com
# - Geocoding API: https://console.cloud.google.com/apis/library/geocoding-backend.googleapis.com
# - Routes API: https://console.cloud.google.com/apis/library/routes.googleapis.com
GOOGLE_PLACES_API_KEY=""

# Required for MC/DOT carrier lookup autocomplete (FMCSA QCMobile API).
# Create a free webKey at https://mobile.fmcsa.dot.gov/QCDevsite/
FMCSA_WEB_KEY=""

# Optional: Socrata app token for FMCSA open-data insurance lookups (higher rate limits).
# Create free at https://data.transportation.gov/profile/edit/developer_settings
# Primary: Motus Insur (c5y8-a4uz) + Motus InsHist (3uet-3z4i).
# Backup when Motus is empty: ActPendInsur (qh9u-swkp) — frozen legacy snapshot, may be stale.
# Works without a token but may throttle.
SOCRATA_APP_TOKEN=""

# Required for dashboard Current Fuel Index (weekly on-highway diesel from EIA).
# Register a free API key at https://www.eia.gov/opendata/register.php
EIA_API_KEY=""

# Stripe billing for organization plans (Free $0 / Lite $20 / Premium $60).
# Create Products + recurring Prices in Stripe Dashboard, then set the Lite/Premium price IDs.
# Optional: STRIPE_SEAT_PRICE_ID for legacy per-seat subscriptions (treated as Premium).
# For development, create a 100% off coupon and promotion code (e.g. DEV100 / tms100).
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
STRIPE_LITE_PRICE_ID=""
STRIPE_PREMIUM_PRICE_ID=""
STRIPE_PREMIUM_TRUCKING_PRICE_ID=""
# STRIPE_SEAT_PRICE_ID=""
STRIPE_DEV_PROMO_CODE="tms100"

# QuickBooks Online (Intuit OAuth + Accounting API).
# Create an app at https://developer.intuit.com/ and set redirect URI to:
#   {APP_BASE_URL}/api/integrations/quickbooks/callback
INTUIT_CLIENT_ID=""
INTUIT_CLIENT_SECRET=""
# Optional — leave unset to derive from APP_BASE_URL. Do not leave localhost
# values in production (they are ignored when APP_BASE_URL is a public URL).
# INTUIT_REDIRECT_URI="http://localhost:3000/api/integrations/quickbooks/callback"
INTUIT_ENVIRONMENT="sandbox"
# 32+ character secret used to encrypt stored OAuth tokens (AES-256-GCM).
# Used for QuickBooks, Gmail, and Microsoft mailbox tokens.
INTUIT_TOKEN_ENCRYPTION_KEY=""
# Optional shared override for ELD / integrations token encryption:
INTEGRATIONS_TOKEN_ENCRYPTION_KEY=""
# Optional shared override (preferred going forward):
# TOKEN_ENCRYPTION_KEY=""

# Google OAuth (sign-in + Gmail mailbox connect).
# Create an OAuth client at https://console.cloud.google.com/apis/credentials
# Enable Google Identity / People API and Gmail API.
# Authorized redirect URIs:
#   {APP_BASE_URL}/api/auth/oauth/google/callback
#   {APP_BASE_URL}/api/mail/oauth/google/callback
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
# Optional — leave unset to derive from APP_BASE_URL. Do not leave localhost
# values in production (they are ignored when APP_BASE_URL is a public URL).
# GOOGLE_REDIRECT_URI="http://localhost:3000/api/auth/oauth/google/callback"
# GOOGLE_MAIL_REDIRECT_URI="http://localhost:3000/api/mail/oauth/google/callback"

# Microsoft 365 OAuth (sign-in + Outlook mailbox connect).
# Register an app at https://portal.azure.com/#view/Microsoft_AAD_RegisteredApps
# Supported account types: personal + work/school (or your tenant).
# API permissions (delegated):
#   Sign-in: openid, profile, email
#   Mailbox connect: User.Read, Mail.Send, Mail.Read, offline_access
# Redirect URIs (Web) — production app registration should ONLY list:
#   {APP_BASE_URL}/api/auth/oauth/microsoft/callback
#   {APP_BASE_URL}/api/mail/oauth/microsoft/callback
# Do NOT leave localhost reply URLs on the production Azure app. Microsoft
# treats localhost ports as interchangeable and may send Cancel/Back responses
# to a different registered localhost port (e.g. :3001).
# Also set Branding → Home page URL to your production APP_BASE_URL.
MICROSOFT_CLIENT_ID=""
MICROSOFT_CLIENT_SECRET=""
# "common" = any Microsoft account (personal + any Entra tenant). Prefer your
# single-tenant GUID in production to lock sign-in to your organization.
# Microsoft emails are never treated as verified for automatic account linking;
# users must sign in with their original method then connect Microsoft in Settings.
MICROSOFT_TENANT_ID="common"
# Optional — leave unset to derive from APP_BASE_URL. Do not leave localhost
# values in production (they are ignored when APP_BASE_URL is a public URL).
# MICROSOFT_REDIRECT_URI="http://localhost:3000/api/auth/oauth/microsoft/callback"
# MICROSOFT_MAIL_REDIRECT_URI="http://localhost:3000/api/mail/oauth/microsoft/callback"

# Required in production. HMAC secret for OAuth state cookies.
# Falls back to TOKEN_ENCRYPTION_KEY / INTUIT_TOKEN_ENCRYPTION_KEY when unset.
# Local dev may omit this (hardcoded fallback); production fails closed without a secret.
# OAUTH_STATE_SECRET=""
