DATABASE_URL="file:./dev.db"
UPLOAD_DIR="./uploads"

# Public URL for password reset links.
APP_BASE_URL="http://localhost:3000"

# Password reset email via Resend (recommended).
# Use a sender on a domain verified in Resend.
RESEND_API_KEY=""
RESEND_FROM="TMS <no-reply@yourdomain.com>"

# Optional Resend SMTP fallback (same API key as RESEND_API_KEY).
# SMTP_HOST="smtp.resend.com"
# SMTP_PORT="587"
# SMTP_USER="resend"
# SMTP_PASS=""
# SMTP_FROM="TMS <no-reply@yourdomain.com>"  # required when using SMTP_* (verified Resend domain)

# Set to "false" when the app is served over plain HTTP (no TLS).
# Leave unset on HTTPS production so secure session cookies are enabled.
# COOKIE_SECURE="false"

# Required for customer business search, location address autocomplete, load route geocoding, and routing.
# Enable these APIs in Google Cloud for the project tied to this key:
# - Places API (New): https://console.cloud.google.com/apis/library/places.googleapis.com
# - Geocoding API: https://console.cloud.google.com/apis/library/geocoding-backend.googleapis.com
# - Routes API: https://console.cloud.google.com/apis/library/routes.googleapis.com
GOOGLE_PLACES_API_KEY=""

# Required for MC/DOT carrier lookup autocomplete (FMCSA QCMobile API).
# Create a free webKey at https://mobile.fmcsa.dot.gov/QCDevsite/
FMCSA_WEB_KEY=""

# Required for dashboard Current Fuel Index (weekly on-highway diesel from EIA).
# Register a free API key at https://www.eia.gov/opendata/register.php
EIA_API_KEY=""

# Stripe billing for per-organization seat subscriptions ($25/seat/month).
# Create a Product + recurring Price in Stripe Dashboard, then set STRIPE_SEAT_PRICE_ID.
# For development, create a 100% off coupon and promotion code (e.g. DEV100).
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
STRIPE_SEAT_PRICE_ID=""
STRIPE_DEV_PROMO_CODE="tms100"

# QuickBooks Online (Intuit OAuth + Accounting API).
# Create an app at https://developer.intuit.com/ and set redirect URI to:
#   {APP_BASE_URL}/api/integrations/quickbooks/callback
INTUIT_CLIENT_ID=""
INTUIT_CLIENT_SECRET=""
INTUIT_REDIRECT_URI="http://localhost:3000/api/integrations/quickbooks/callback"
INTUIT_ENVIRONMENT="sandbox"
# 32+ character secret used to encrypt stored OAuth tokens (AES-256-GCM).
# Used for QuickBooks, Gmail, and Microsoft mailbox tokens.
INTUIT_TOKEN_ENCRYPTION_KEY=""
# Optional shared override (preferred going forward):
# TOKEN_ENCRYPTION_KEY=""

# Google OAuth (sign-in + Gmail mailbox connect).
# Create an OAuth client at https://console.cloud.google.com/apis/credentials
# Enable Google Identity / People API and Gmail API.
# Authorized redirect URIs:
#   {APP_BASE_URL}/api/auth/oauth/google/callback
#   {APP_BASE_URL}/api/mail/oauth/google/callback
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="http://localhost:3000/api/auth/oauth/google/callback"
GOOGLE_MAIL_REDIRECT_URI="http://localhost:3000/api/mail/oauth/google/callback"

# Microsoft 365 OAuth (sign-in + Outlook mailbox connect).
# Register an app at https://portal.azure.com/#view/Microsoft_AAD_RegisteredApps
# Supported account types: personal + work/school (or your tenant).
# API permissions (delegated): openid, profile, email, User.Read, Mail.Send, Mail.Read, offline_access
# Redirect URIs (Web):
#   {APP_BASE_URL}/api/auth/oauth/microsoft/callback
#   {APP_BASE_URL}/api/mail/oauth/microsoft/callback
MICROSOFT_CLIENT_ID=""
MICROSOFT_CLIENT_SECRET=""
MICROSOFT_TENANT_ID="common"
MICROSOFT_REDIRECT_URI="http://localhost:3000/api/auth/oauth/microsoft/callback"
MICROSOFT_MAIL_REDIRECT_URI="http://localhost:3000/api/mail/oauth/microsoft/callback"

# Optional HMAC secret for OAuth state cookies (falls back to TOKEN_ENCRYPTION_KEY).
# OAUTH_STATE_SECRET=""
