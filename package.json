{
  "name": "freight-broker-tms",
  "version": "0.5.0",
  "private": true,
  "scripts": {
    "dev": "prisma generate && prisma migrate deploy && next dev --webpack",
    "build": "prisma generate && next build",
    "start": "node -r dotenv/config ./node_modules/next/dist/bin/next start",
    "worker": "tsx scripts/job-worker.ts",
    "lint": "eslint . --max-warnings=0",
    "test": "tsx --test lib/**/*.test.ts",
    "postinstall": "prisma generate",
    "setup": "prisma generate && prisma migrate deploy && prisma db seed",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:migrate:dev": "prisma migrate dev",
    "db:seed": "prisma db seed",
    "db:import-ascend": "tsx prisma/ascend-load-import.ts",
    "db:backfill-facilities": "tsx prisma/backfill-facilities.ts",
    "db:reset": "prisma migrate reset --force"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1087.0",
    "@prisma/client": "^6",
    "@turf/turf": "^7.3.5",
    "@types/leaflet": "^1.9.21",
    "clsx": "latest",
    "jspdf": "^2.5.2",
    "jspdf-autotable": "^3.8.4",
    "leaflet": "^1.9.4",
    "lucide-react": "latest",
    "next": "latest",
    "nodemailer": "^9.0.3",
    "react": "latest",
    "react-dom": "latest",
    "react-leaflet": "^5.0.0",
    "recharts": "^3.9.2",
    "redis": "^5.12.1",
    "server-only": "^0.0.1",
    "stripe": "^18.5.0",
    "zod": "latest"
  },
  "devDependencies": {
    "@eslint/eslintrc": "latest",
    "@tailwindcss/postcss": "latest",
    "@types/node": "latest",
    "@types/nodemailer": "^8.0.1",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "autoprefixer": "latest",
    "dotenv": "^17.4.2",
    "eslint": "latest",
    "eslint-config-next": "latest",
    "postcss": "latest",
    "prisma": "^6",
    "tailwindcss": "latest",
    "tsx": "latest",
    "typescript": "latest"
  }
}
