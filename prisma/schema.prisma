generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Company {
  id                   String                 @id @default(cuid())
  name                 String
  slug                 String                 @unique
  status               String                 @default("ACTIVE")
  loadNumberPrefix     String                 @default("GLB")
  nextLoadSequence     Int                    @default(1001)
  /// NONE | ONLINE | IIF — active QuickBooks export method
  quickbooksMethod     String                 @default("NONE")
  /// JSON: AR/AP/income/expense account names and item defaults
  quickbooksConfigJson String?
  logoFilePath         String?
  logoMimeType         String?
  logoOriginalFileName String?
  address              String?
  city                 String?
  state                String?
  postalCode           String?
  phone                String?
  email                String?
  website              String?
  memberships          CompanyMembership[]
  seatSubscription     SeatSubscription?
  branches             Branch[]
  customers            Customer[]
  carriers             Carrier[]
  facilities           Facility[]
  loads                Load[]
  documents            LoadDocument[]
  invoices             Invoice[]
  carrierBills         CarrierBill[]
  integrationAccounts  IntegrationAccount[]
  accountingExports    AccountingExport[]
  auditLogs            AuditLog[]
  commissionProfiles   CommissionProfile[]
  emailThreads         EmailThread[]
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt
}

model Branch {
  id                   String             @id @default(cuid())
  companyId            String
  company              Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name                 String
  city                 String?
  state                String?
  commissionProfileId  String?
  commissionProfile    CommissionProfile? @relation(fields: [commissionProfileId], references: [id])
  memberships          CompanyMembership[]
  membershipBranches   MembershipBranch[]
  customers            Customer[]
  carriers             Carrier[]
  facilities           Facility[]
  loads                Load[]
  loadCommissions      LoadCommission[]
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  @@index([companyId])
}

model User {
  id                     String              @id @default(cuid())
  name                   String
  email                  String              @unique
  passwordHash           String?
  mustChangePassword     Boolean             @default(false)
  lastLoginAt            DateTime?
  passwordResetAt        DateTime?
  passwordResetTokenHash   String?             @unique
  passwordResetExpiresAt   DateTime?
  memberships            CompanyMembership[]
  notes                  LoadNote[]
  activities             LoadActivity[]
  sessions               Session[]
  auditLogs              AuditLog[]          @relation("AuditActor")
  targetAuditLogs        AuditLog[]          @relation("AuditTargetUser")
  settledCommissions     LoadCommission[]
  documents              LoadDocument[]
  oauthAccounts          OAuthAccount[]
  mailboxes              UserMailbox[]
  emailThreads           EmailThread[]
  emailMessages          EmailMessage[]
  createdAt              DateTime            @default(now())
  updatedAt              DateTime            @updatedAt
}

model OAuthAccount {
  id                String   @id @default(cuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider          String
  providerAccountId String
  email             String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([provider, providerAccountId])
  @@unique([userId, provider])
  @@index([userId])
}

model UserMailbox {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider        String
  emailAddress    String
  accessTokenEnc  String?
  refreshTokenEnc String?
  tokenExpiresAt  DateTime?
  scopes          String?
  status          String    @default("CONNECTED")
  lastSyncAt      DateTime?
  lastError       String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([userId, provider])
  @@index([userId])
}

model EmailThread {
  id                 String         @id @default(cuid())
  companyId          String
  company            Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  loadId             String
  load               Load           @relation(fields: [loadId], references: [id], onDelete: Cascade)
  userId             String
  user               User           @relation(fields: [userId], references: [id])
  purpose            String
  subject            String
  provider           String
  providerThreadId   String?
  documentId         String?
  document           LoadDocument?  @relation(fields: [documentId], references: [id])
  invoiceId          String?
  invoice            Invoice?       @relation(fields: [invoiceId], references: [id])
  messages           EmailMessage[]
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  @@index([companyId])
  @@index([loadId])
  @@index([userId])
  @@index([providerThreadId])
}

model EmailMessage {
  id                 String      @id @default(cuid())
  threadId           String
  thread             EmailThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  userId             String?
  user               User?       @relation(fields: [userId], references: [id])
  direction          String
  fromAddress        String
  toAddresses        String
  subject            String
  bodyPreview        String?
  bodyText           String?
  providerMessageId  String?
  sentAt             DateTime?
  receivedAt         DateTime?
  createdAt          DateTime    @default(now())

  @@unique([threadId, providerMessageId])
  @@index([threadId])
}

model CompanyMembership {
  id              String             @id @default(cuid())
  userId          String
  user            User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyId       String
  company         Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  role            String             @default("BROKER")
  status          String             @default("ACTIVE")
  branchId        String?
  branch          Branch?            @relation(fields: [branchId], references: [id])
  assignedBranches MembershipBranch[]
  seatAssignedAt  DateTime?
  inviteTokenHash String?            @unique
  inviteExpiresAt DateTime?
  lockedAt        DateTime?
  disabledAt      DateTime?
  sessions        Session[]
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@unique([userId, companyId])
  @@index([companyId])
}

model MembershipBranch {
  id           String            @id @default(cuid())
  membershipId String
  membership   CompanyMembership @relation(fields: [membershipId], references: [id], onDelete: Cascade)
  branchId     String
  branch       Branch            @relation(fields: [branchId], references: [id], onDelete: Cascade)
  createdAt    DateTime          @default(now())

  @@unique([membershipId, branchId])
  @@index([membershipId])
  @@index([branchId])
}

model SeatSubscription {
  id                   String    @id @default(cuid())
  companyId            String    @unique
  company              Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  stripeCustomerId     String?   @unique
  stripeSubscriptionId String?   @unique
  stripePriceId        String?
  seatQuantity         Int       @default(0)
  status               String    @default("NONE")
  currentPeriodEnd     DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
}

model Session {
  id           String            @id @default(cuid())
  tokenHash    String            @unique
  userId       String
  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  membershipId String
  membership   CompanyMembership @relation(fields: [membershipId], references: [id], onDelete: Cascade)
  expiresAt    DateTime
  lastSeenAt   DateTime          @default(now())
  createdAt    DateTime          @default(now())
}

model AuditLog {
  id           String   @id @default(cuid())
  companyId    String?
  company      Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)
  actorUserId  String?
  actorUser    User?    @relation("AuditActor", fields: [actorUserId], references: [id])
  targetUserId String?
  targetUser   User?    @relation("AuditTargetUser", fields: [targetUserId], references: [id])
  action       String
  entityType   String
  entityId     String?
  details      String?
  ipAddress    String?
  createdAt    DateTime @default(now())

  @@index([companyId])
}

model Customer {
  id            String            @id @default(cuid())
  companyId     String
  company       Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name          String
  status        String            @default("Active")
  creditLimit   Int               @default(0)
  paymentTerms  String            @default("Net 30")
  industry      String?
  phone         String?
  email         String?
  address       String?
  city          String?
  state         String?
  postalCode    String?
  externalQboId String?
  branchId      String?
  branch        Branch?           @relation(fields: [branchId], references: [id])
  contacts      CustomerContact[]
  facilities    Facility[]
  loads         Load[]
  documents     LoadDocument[]
  invoices      Invoice[]
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@index([companyId])
}

model CustomerContact {
  id         String   @id @default(cuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  name       String
  title      String?
  email      String?
  phone      String?
  isPrimary  Boolean  @default(false)
}

model Carrier {
  id                  String                      @id @default(cuid())
  companyId           String
  company             Company                     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name                String
  status              String                      @default("Active")
  mcNumber            String?
  mcNumberNormalized  String?
  dotNumber           String?
  dotNumberNormalized String?
  phone               String?
  email               String?
  address             String?
  city                String?
  state               String?
  postalCode          String?
  equipmentTypes      String?
  safetyRating        String?
  insuranceExpiresAt  DateTime?
  complianceStatus    String                      @default("Needs Review")
  externalQboId       String?
  branchId            String?
  branch              Branch?                     @relation(fields: [branchId], references: [id])
  contacts            CarrierContact[]
  complianceDocuments CarrierComplianceDocument[]
  insuranceCoverages  CarrierInsuranceCoverage[]
  assignments         DispatchAssignment[]
  documents           LoadDocument[]
  carrierBills        CarrierBill[]
  createdAt           DateTime                    @default(now())
  updatedAt           DateTime                    @updatedAt

  @@index([companyId])
  @@index([companyId, mcNumberNormalized])
  @@index([companyId, dotNumberNormalized])
}

model CarrierContact {
  id        String  @id @default(cuid())
  carrierId String
  carrier   Carrier @relation(fields: [carrierId], references: [id], onDelete: Cascade)
  name      String
  title     String?
  email     String?
  phone     String?
  isPrimary Boolean @default(false)
}

model CarrierComplianceDocument {
  id          String       @id @default(cuid())
  carrierId   String
  carrier     Carrier      @relation(fields: [carrierId], references: [id], onDelete: Cascade)
  type        String
  name        String
  filePath    String?
  expiresAt   DateTime?
  status      String       @default("Current")
  uploadedAt  DateTime     @default(now())
}

model CarrierInsuranceCoverage {
  id            String    @id @default(cuid())
  carrierId     String
  carrier       Carrier   @relation(fields: [carrierId], references: [id], onDelete: Cascade)
  coverageType  String
  insurerName   String?
  policyNumber  String?
  limitAmount   String?
  effectiveAt   DateTime?
  expiresAt     DateTime?
  status        String    @default("Current")
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Facility {
  id          String      @id @default(cuid())
  companyId   String
  company     Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customerId  String?
  customer    Customer?   @relation(fields: [customerId], references: [id])
  branchId    String?
  branch      Branch?     @relation(fields: [branchId], references: [id])
  name        String
  type        String      @default("GENERAL")
  status      String      @default("Active")
  address     String?
  city        String
  state       String
  postalCode  String?
  phone       String?
  email       String?
  contactName String?
  notes       String?
  loadStops   LoadStop[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([companyId])
  @@index([customerId])
}

model Load {
  id                String              @id @default(cuid())
  companyId         String
  company           Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  loadNumber        String
  title             String
  status            String              @default("QUOTE")
  customerId        String
  customer          Customer            @relation(fields: [customerId], references: [id])
  branchId          String?
  branch            Branch?             @relation(fields: [branchId], references: [id])
  referenceNumber   String?
  equipmentType     String              @default("Dry Van")
  commodity         String?
  weight            Int?
  pickupCity        String
  pickupState       String
  deliveryCity      String
  deliveryState     String
  pickupDate        DateTime
  deliveryDate      DateTime
  revenueCents         Int                 @default(0)
  carrierCostCents     Int                 @default(0)
  isCommissionable     Boolean             @default(true)
  commissionProfileId  String?
  commissionProfile    CommissionProfile?  @relation(fields: [commissionProfileId], references: [id])
  stops                LoadStop[]
  charges              LoadCharge[]
  expenses             LoadExpense[]
  documents            LoadDocument[]
  notes                LoadNote[]
  activities           LoadActivity[]
  dispatchAssignment   DispatchAssignment?
  invoices             Invoice[]
  carrierBills         CarrierBill[]
  commission           LoadCommission?
  emailThreads         EmailThread[]
  routeTotalMiles      Float?
  routeStateMiles      Json?
  routePolyline        String?
  routeComputedAt      DateTime?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt

  @@unique([companyId, loadNumber])
  @@index([companyId])
}

model LoadStop {
  id            String    @id @default(cuid())
  loadId        String
  load          Load      @relation(fields: [loadId], references: [id], onDelete: Cascade)
  facilityId    String?
  facility      Facility? @relation(fields: [facilityId], references: [id])
  type          String
  sequence      Int
  facilityName  String
  address       String?
  city          String
  state         String
  postalCode    String?
  appointmentAt DateTime?
  actualAt      DateTime?
  instructions  String?
}

model LoadCharge {
  id          String   @id @default(cuid())
  loadId      String
  load        Load     @relation(fields: [loadId], references: [id], onDelete: Cascade)
  label       String
  chargeType  String   @default("Linehaul")
  amountCents Int
}

model LoadExpense {
  id          String   @id @default(cuid())
  loadId      String
  load        Load     @relation(fields: [loadId], references: [id], onDelete: Cascade)
  label       String
  expenseType String   @default("Other")
  amountCents Int
}

model CommissionProfile {
  id        String                  @id @default(cuid())
  companyId String
  company   Company                 @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name      String
  isDefault Boolean                 @default(false)
  rule      CommissionProfileRule?
  branches  Branch[]
  loads     Load[]
  commissions LoadCommission[]
  createdAt DateTime                @default(now())
  updatedAt DateTime                @updatedAt

  @@index([companyId])
}

model CommissionProfileRule {
  id                          String            @id @default(cuid())
  profileId                   String            @unique
  profile                     CommissionProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  branchSharePercent          Int               @default(60)
  companySharePercent         Int               @default(40)
  companyMinimumExpensePercent Int              @default(10)
}

model LoadCommission {
  id                 String            @id @default(cuid())
  loadId             String            @unique
  load               Load              @relation(fields: [loadId], references: [id], onDelete: Cascade)
  branchId           String?
  branch             Branch?           @relation(fields: [branchId], references: [id])
  profileId          String?
  profile            CommissionProfile? @relation(fields: [profileId], references: [id])
  profileName        String
  isCommissionable   Boolean           @default(true)
  revenueCents       Int               @default(0)
  grossExpenseCents  Int               @default(0)
  grossProfitCents   Int               @default(0)
  branchShareCents   Int               @default(0)
  companyShareCents  Int               @default(0)
  calculationMethod  String            @default("STANDARD_SPLIT")
  status             String            @default("PENDING")
  payableAt          DateTime?
  settledAt          DateTime?
  settledByUserId    String?
  settledByUser      User?             @relation(fields: [settledByUserId], references: [id])
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  @@index([branchId])
  @@index([status])
}

model DispatchAssignment {
  id             String      @id @default(cuid())
  loadId         String      @unique
  load           Load        @relation(fields: [loadId], references: [id], onDelete: Cascade)
  carrierId      String
  carrier        Carrier     @relation(fields: [carrierId], references: [id])
  driverName     String?
  driverPhone    String?
  truckNumber    String?
  trailerNumber  String?
  rateCents      Int         @default(0)
  assignedAt     DateTime    @default(now())
  checkCalls     CheckCall[]
}

model CheckCall {
  id           String             @id @default(cuid())
  assignmentId String
  assignment   DispatchAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  location     String
  status       String
  notes        String?
  occurredAt   DateTime           @default(now())
  nextCheckAt  DateTime?
}

model LoadDocument {
  id                String    @id @default(cuid())
  companyId         String
  company           Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  loadId            String?
  load              Load?     @relation(fields: [loadId], references: [id], onDelete: Cascade)
  customerId        String?
  customer          Customer? @relation(fields: [customerId], references: [id])
  carrierId         String?
  carrier           Carrier?  @relation(fields: [carrierId], references: [id])
  uploadedById      String?
  uploadedBy        User?     @relation(fields: [uploadedById], references: [id])
  type              String
  types             String?
  name              String
  documentNumber    String?
  filePath          String?
  originalFileName  String?
  mimeType          String?
  fileSizeBytes     Int?
  notes             String?
  status            String    @default("PROCESSED")
  isCompanyDocument Boolean   @default(false)
  generatedContent  String?
  generatedAt       DateTime?
  uploadedAt        DateTime  @default(now())
  updatedAt         DateTime  @default(now()) @updatedAt
  emailThreads      EmailThread[]

  @@index([companyId])
  @@index([loadId])
  @@index([customerId])
  @@index([carrierId])
}

model LoadNote {
  id        String   @id @default(cuid())
  loadId    String
  load      Load     @relation(fields: [loadId], references: [id], onDelete: Cascade)
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  body      String
  createdAt DateTime @default(now())
}

model LoadActivity {
  id        String   @id @default(cuid())
  loadId    String
  load      Load     @relation(fields: [loadId], references: [id], onDelete: Cascade)
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  action    String
  details   String?
  createdAt DateTime @default(now())
}

model Invoice {
  id            String        @id @default(cuid())
  companyId     String
  company       Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  invoiceNo     String
  loadId        String
  load          Load          @relation(fields: [loadId], references: [id])
  customerId    String
  customer      Customer      @relation(fields: [customerId], references: [id])
  status        String        @default("DRAFT")
  totalCents    Int
  issuedAt      DateTime?
  dueAt         DateTime?
  paidAt        DateTime?
  externalQboId String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  emailThreads  EmailThread[]

  @@unique([companyId, invoiceNo])
  @@index([companyId])
}

model CarrierBill {
  id            String        @id @default(cuid())
  companyId     String
  company       Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  billNo        String
  loadId        String
  load          Load          @relation(fields: [loadId], references: [id])
  carrierId     String
  carrier       Carrier       @relation(fields: [carrierId], references: [id])
  status        String        @default("DRAFT")
  totalCents    Int
  receivedAt    DateTime?
  dueAt         DateTime?
  paidAt        DateTime?
  externalQboId String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@unique([companyId, billNo])
  @@index([companyId])
}

model IntegrationAccount {
  id               String    @id @default(cuid())
  companyId        String
  company          Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  provider         String
  displayName      String
  status           String    @default("Not Connected")
  apiKeyLast4      String?
  notes            String?
  realmId          String?
  accessTokenEnc   String?
  refreshTokenEnc  String?
  tokenExpiresAt   DateTime?
  connectedAt      DateTime?
  lastSyncAt       DateTime?
  lastError        String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([companyId])
  @@unique([companyId, provider])
}

/// Per-method export history for invoices and carrier bills (ONLINE vs IIF are independent).
model AccountingExport {
  id               String    @id @default(cuid())
  companyId        String
  company          Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  entityType       String
  entityId         String
  method           String
  status           String    @default("SYNCED")
  exportedAt       DateTime?
  externalId       String?
  message          String?
  exportedByUserId String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@unique([entityType, entityId, method])
  @@index([companyId, method])
  @@index([companyId, entityType, entityId])
}
