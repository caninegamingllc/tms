generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Company {
  id                   String                 @id @default(cuid())
  name                 String
  slug                 String                 @unique
  status               String                 @default("ACTIVE")
  loadNumberPrefix     String                 @default("GLB")
  nextLoadSequence     Int                    @default(1001)
  /// NONE | ONLINE | IIF — active QuickBooks export method
  quickbooksMethod     String                 @default("NONE")
  /// JSON: AR/AP/income/expense account names and item defaults
  quickbooksConfigJson String?
  logoFilePath         String?
  logoMimeType         String?
  logoOriginalFileName String?
  address              String?
  city                 String?
  state                String?
  postalCode           String?
  phone                String?
  email                String?
  website              String?
  /// Optional remittance / pay-portal URL shown on customer portal invoices
  customerPaymentUrl   String?
  memberships          CompanyMembership[]
  seatSubscription     SeatSubscription?
  branches             Branch[]
  customers            Customer[]
  carriers             Carrier[]
  facilities           Facility[]
  loads                Load[]
  documents            LoadDocument[]
  invoices             Invoice[]
  carrierBills         CarrierBill[]
  factoringCompanies   FactoringCompany[]
  payments             Payment[]
  integrationAccounts  IntegrationAccount[]
  accountingExports    AccountingExport[]
  auditLogs            AuditLog[]
  commissionProfiles   CommissionProfile[]
  emailThreads         EmailThread[]
  commodityOptions      CommodityOption[]
  carrierPayLineTypes   CarrierPayLineType[]
  customerChargeTypes   CustomerChargeType[]
  portalUsers           CustomerPortalUser[]
  portalLinks           CustomerPortalLink[]
  drivers               Driver[]
  trucks                Truck[]
  trailers              Trailer[]
  equipmentMaintenanceLogs EquipmentMaintenanceLog[]
  safetyEvents          SafetyEvent[]
  iftaQuarters          IftaQuarter[]
  dvirReports           DvirReport[]
  driverSettlements     DriverSettlement[]
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
}

model CommodityOption {
  id        String   @id @default(cuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name      String
  active    Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, name])
  @@index([companyId])
}

model CarrierPayLineType {
  id                 String          @id @default(cuid())
  companyId          String
  company            Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name               String
  /// FLAT | PER_MILE | HOURLY
  calculationMethod  String          @default("FLAT")
  active             Boolean         @default(true)
  sortOrder          Int             @default(0)
  isSystem           Boolean         @default(false)
  payLines           CarrierPayLine[]
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  @@unique([companyId, name])
  @@index([companyId])
}

model CustomerChargeType {
  id                 String       @id @default(cuid())
  companyId          String
  company            Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name               String
  /// FLAT | PER_MILE | HOURLY
  calculationMethod  String       @default("FLAT")
  active             Boolean      @default(true)
  sortOrder          Int          @default(0)
  isSystem           Boolean      @default(false)
  charges            LoadCharge[]
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  @@unique([companyId, name])
  @@index([companyId])
}

model Branch {
  id                   String             @id @default(cuid())
  companyId            String
  company              Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name                 String
  city                 String?
  state                String?
  commissionProfileId  String?
  commissionProfile    CommissionProfile? @relation(fields: [commissionProfileId], references: [id])
  memberships          CompanyMembership[]
  membershipBranches   MembershipBranch[]
  customers            Customer[]
  carriers             Carrier[]
  facilities           Facility[]
  loads                Load[]
  loadCommissions      LoadCommission[]
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  @@index([companyId])
}

model User {
  id                     String              @id @default(cuid())
  name                   String
  email                  String              @unique
  passwordHash           String?
  mustChangePassword     Boolean             @default(false)
  lastLoginAt            DateTime?
  passwordResetAt        DateTime?
  passwordResetTokenHash   String?             @unique
  passwordResetExpiresAt   DateTime?
  uiPreferences          Json?
  legalAcceptedAt        DateTime?
  legalDocumentVersion   String?
  memberships            CompanyMembership[]
  notes                  LoadNote[]
  activities             LoadActivity[]
  customerActivities     CustomerActivity[]
  carrierActivities      CarrierActivity[]
  sessions               Session[]
  auditLogs              AuditLog[]          @relation("AuditActor")
  targetAuditLogs        AuditLog[]          @relation("AuditTargetUser")
  settledCommissions     LoadCommission[]
  documents              LoadDocument[]
  oauthAccounts          OAuthAccount[]
  mailboxes              UserMailbox[]
  emailThreads           EmailThread[]
  emailMessages          EmailMessage[]
  createdAt              DateTime            @default(now())
  updatedAt              DateTime            @updatedAt
}

model OAuthAccount {
  id                String   @id @default(cuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider          String
  providerAccountId String
  email             String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([provider, providerAccountId])
  @@unique([userId, provider])
  @@index([userId])
}

model UserMailbox {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider        String
  emailAddress    String
  accessTokenEnc  String?
  refreshTokenEnc String?
  tokenExpiresAt  DateTime?
  scopes          String?
  status          String    @default("CONNECTED")
  lastSyncAt      DateTime?
  lastError       String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([userId, provider])
  @@index([userId])
}

model EmailThread {
  id                 String         @id @default(cuid())
  companyId          String
  company            Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  loadId             String
  load               Load           @relation(fields: [loadId], references: [id], onDelete: Cascade)
  userId             String
  user               User           @relation(fields: [userId], references: [id])
  purpose            String
  subject            String
  provider           String
  providerThreadId   String?
  documentId         String?
  document           LoadDocument?  @relation(fields: [documentId], references: [id])
  invoiceId          String?
  invoice            Invoice?       @relation(fields: [invoiceId], references: [id])
  messages           EmailMessage[]
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  @@index([companyId])
  @@index([loadId])
  @@index([userId])
  @@index([providerThreadId])
}

model EmailMessage {
  id                 String      @id @default(cuid())
  threadId           String
  thread             EmailThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  userId             String?
  user               User?       @relation(fields: [userId], references: [id])
  direction          String
  fromAddress        String
  toAddresses        String
  subject            String
  bodyPreview        String?
  bodyText           String?
  providerMessageId  String?
  sentAt             DateTime?
  receivedAt         DateTime?
  createdAt          DateTime    @default(now())

  @@unique([threadId, providerMessageId])
  @@index([threadId])
}

model CompanyMembership {
  id              String             @id @default(cuid())
  userId          String
  user            User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyId       String
  company         Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  role            String             @default("BROKER")
  status          String             @default("ACTIVE")
  branchId        String?
  branch          Branch?            @relation(fields: [branchId], references: [id])
  assignedBranches MembershipBranch[]
  seatAssignedAt  DateTime?
  inviteTokenHash String?            @unique
  inviteExpiresAt DateTime?
  lockedAt        DateTime?
  disabledAt      DateTime?
  sessions        Session[]
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@unique([userId, companyId])
  @@index([companyId])
}

model MembershipBranch {
  id           String            @id @default(cuid())
  membershipId String
  membership   CompanyMembership @relation(fields: [membershipId], references: [id], onDelete: Cascade)
  branchId     String
  branch       Branch            @relation(fields: [branchId], references: [id], onDelete: Cascade)
  createdAt    DateTime          @default(now())

  @@unique([membershipId, branchId])
  @@index([membershipId])
  @@index([branchId])
}

model SeatSubscription {
  id                   String    @id @default(cuid())
  companyId            String    @unique
  company              Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  stripeCustomerId     String?   @unique
  stripeSubscriptionId String?   @unique
  stripePriceId        String?
  /// FREE | LITE | PREMIUM | PREMIUM_TRUCKING — feature package for this organization
  plan                 String    @default("FREE")
  seatQuantity         Int       @default(0)
  status               String    @default("NONE")
  currentPeriodEnd     DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
}

model Session {
  id           String            @id @default(cuid())
  tokenHash    String            @unique
  userId       String
  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  membershipId String
  membership   CompanyMembership @relation(fields: [membershipId], references: [id], onDelete: Cascade)
  expiresAt    DateTime
  lastSeenAt   DateTime          @default(now())
  createdAt    DateTime          @default(now())
}

model AuditLog {
  id           String   @id @default(cuid())
  companyId    String?
  company      Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)
  actorUserId  String?
  actorUser    User?    @relation("AuditActor", fields: [actorUserId], references: [id])
  targetUserId String?
  targetUser   User?    @relation("AuditTargetUser", fields: [targetUserId], references: [id])
  action       String
  entityType   String
  entityId     String?
  details      String?
  ipAddress    String?
  createdAt    DateTime @default(now())

  @@index([companyId])
}

model Customer {
  id            String            @id @default(cuid())
  companyId     String
  company       Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name          String
  status        String            @default("Active")
  creditLimit   Int               @default(0)
  paymentTerms  String            @default("Net 30")
  /// Percent of original (non–late-fee) invoice amount charged per overdue terms period on invoice email send.
  lateFeePercent Float            @default(0)
  /// Default carrier rate confirmation terms (appended after built-in terms).
  rateConfirmationTerms String?
  industry      String?
  phone         String?
  email         String?
  address       String?
  city          String?
  state         String?
  postalCode    String?
  externalQboId String?
  /// Optional per-customer pay URL; falls back to Company.customerPaymentUrl
  paymentUrl    String?
  branchId      String?
  branch        Branch?           @relation(fields: [branchId], references: [id])
  contacts      CustomerContact[]
  facilities    Facility[]
  loads         Load[]
  documents     LoadDocument[]
  invoices      Invoice[]
  payments      Payment[]
  activities    CustomerActivity[]
  portalUsers   CustomerPortalUser[]
  portalLinks   CustomerPortalLink[]
  portalSessions CustomerPortalSession[]
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@index([companyId])
}

model CustomerPortalUser {
  id              String                  @id @default(cuid())
  companyId       String
  company         Company                 @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customerId      String
  customer        Customer                @relation(fields: [customerId], references: [id], onDelete: Cascade)
  name            String
  email           String
  passwordHash    String?
  status          String                  @default("INVITED")
  inviteTokenHash String?                 @unique
  inviteExpiresAt DateTime?
  disabledAt      DateTime?
  sessions        CustomerPortalSession[]
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt

  @@unique([companyId, email])
  @@index([customerId])
  @@index([companyId])
}

model CustomerPortalLink {
  id              String                  @id @default(cuid())
  companyId       String
  company         Company                 @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customerId      String
  customer        Customer                @relation(fields: [customerId], references: [id], onDelete: Cascade)
  label           String                  @default("Share link")
  tokenHash       String                  @unique
  expiresAt       DateTime?
  revokedAt       DateTime?
  createdByUserId String?
  sessions        CustomerPortalSession[]
  createdAt       DateTime                @default(now())

  @@index([customerId])
  @@index([companyId])
}

model CustomerPortalSession {
  id           String              @id @default(cuid())
  tokenHash    String              @unique
  customerId   String
  customer     Customer            @relation(fields: [customerId], references: [id], onDelete: Cascade)
  portalUserId String?
  portalUser   CustomerPortalUser? @relation(fields: [portalUserId], references: [id], onDelete: Cascade)
  portalLinkId String?
  portalLink   CustomerPortalLink? @relation(fields: [portalLinkId], references: [id], onDelete: Cascade)
  expiresAt    DateTime
  lastSeenAt   DateTime            @default(now())
  createdAt    DateTime            @default(now())

  @@index([customerId])
  @@index([portalUserId])
  @@index([portalLinkId])
}

model CustomerActivity {
  id         String   @id @default(cuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  userId     String?
  user       User?    @relation(fields: [userId], references: [id])
  action     String
  details    String?
  createdAt  DateTime @default(now())

  @@index([customerId])
}

model CustomerContact {
  id         String   @id @default(cuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  name       String
  title      String?
  email      String?
  phone      String?
  isPrimary  Boolean  @default(false)
}

model FactoringCompany {
  id            String        @id @default(cuid())
  companyId     String
  company       Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name          String
  nameOnCheck   String
  phone         String?
  email         String?
  address       String?
  city          String?
  state         String?
  postalCode    String?
  status        String        @default("Active")
  externalQboId String?
  carriers      Carrier[]
  carrierBills  CarrierBill[]
  payments      Payment[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@unique([companyId, name])
  @@index([companyId])
}

model Carrier {
  id                  String                      @id @default(cuid())
  companyId           String
  company             Company                     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name                String
  status              String                      @default("Active")
  mcNumber            String?
  mcNumberNormalized  String?
  dotNumber           String?
  dotNumberNormalized String?
  phone               String?
  email               String?
  address             String?
  city                String?
  state               String?
  postalCode          String?
  equipmentTypes      String?
  safetyRating        String?
  insuranceExpiresAt  DateTime?
  complianceStatus    String                      @default("Needs Review")
  paymentTerms        String                      @default("Net 30")
  paymentMethod       String?
  factoringCompanyId  String?
  factoringCompany    FactoringCompany?           @relation(fields: [factoringCompanyId], references: [id], onDelete: SetNull)
  externalQboId       String?
  branchId            String?
  branch              Branch?                     @relation(fields: [branchId], references: [id])
  contacts            CarrierContact[]
  complianceDocuments CarrierComplianceDocument[]
  insuranceCoverages  CarrierInsuranceCoverage[]
  assignments         DispatchAssignment[]
  documents           LoadDocument[]
  carrierBills        CarrierBill[]
  payments            Payment[]
  activities          CarrierActivity[]
  createdAt           DateTime                    @default(now())
  updatedAt           DateTime                    @updatedAt

  @@index([companyId])
  @@index([companyId, mcNumberNormalized])
  @@index([companyId, dotNumberNormalized])
  @@index([factoringCompanyId])
}

model CarrierActivity {
  id        String   @id @default(cuid())
  carrierId String
  carrier   Carrier  @relation(fields: [carrierId], references: [id], onDelete: Cascade)
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  action    String
  details   String?
  createdAt DateTime @default(now())

  @@index([carrierId])
}

model CarrierContact {
  id        String  @id @default(cuid())
  carrierId String
  carrier   Carrier @relation(fields: [carrierId], references: [id], onDelete: Cascade)
  name      String
  title     String?
  email     String?
  phone     String?
  isPrimary Boolean @default(false)
}

model CarrierComplianceDocument {
  id          String       @id @default(cuid())
  carrierId   String
  carrier     Carrier      @relation(fields: [carrierId], references: [id], onDelete: Cascade)
  type        String
  name        String
  filePath    String?
  expiresAt   DateTime?
  status      String       @default("Current")
  uploadedAt  DateTime     @default(now())
}

model CarrierInsuranceCoverage {
  id            String    @id @default(cuid())
  carrierId     String
  carrier       Carrier   @relation(fields: [carrierId], references: [id], onDelete: Cascade)
  coverageType  String
  insurerName   String?
  policyNumber  String?
  limitAmount   String?
  effectiveAt   DateTime?
  expiresAt     DateTime?
  status        String    @default("Current")
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Facility {
  id          String      @id @default(cuid())
  companyId   String
  company     Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customerId  String?
  customer    Customer?   @relation(fields: [customerId], references: [id])
  branchId    String?
  branch      Branch?     @relation(fields: [branchId], references: [id])
  name        String
  type        String      @default("GENERAL")
  status      String      @default("Active")
  address     String?
  city        String
  state       String
  postalCode  String?
  phone       String?
  email       String?
  contactName String?
  notes       String?
  loadStops   LoadStop[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([companyId])
  @@index([customerId])
}

model Load {
  id                String              @id @default(cuid())
  companyId         String
  company           Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  loadNumber        String
  title             String
  status            String              @default("QUOTE")
  customerId        String
  customer          Customer            @relation(fields: [customerId], references: [id])
  branchId          String?
  branch            Branch?             @relation(fields: [branchId], references: [id])
  referenceNumber   String?
  equipmentType     String              @default("Dry Van")
  /// Required setpoint when equipment is Reefer (°F).
  reeferTempF       Float?
  commodity         String?
  weight            Int?
  pickupCity        String
  pickupState       String
  deliveryCity      String
  deliveryState     String
  pickupDate        DateTime
  deliveryDate      DateTime
  revenueCents         Int                 @default(0)
  carrierCostCents     Int                 @default(0)
  isCommissionable     Boolean             @default(true)
  /// Load-level rate con terms override; blank inherits customer default.
  rateConfirmationTerms String?
  commissionProfileId  String?
  commissionProfile    CommissionProfile?  @relation(fields: [commissionProfileId], references: [id])
  stops                LoadStop[]
  commodityLines       LoadCommodityLine[]
  charges              LoadCharge[]
  expenses             LoadExpense[]
  carrierPayLines      CarrierPayLine[]
  documents            LoadDocument[]
  notes                LoadNote[]
  activities           LoadActivity[]
  dispatchAssignments  DispatchAssignment[]
  invoices             Invoice[]
  carrierBills         CarrierBill[]
  commission           LoadCommission?
  emailThreads         EmailThread[]
  safetyEvents         SafetyEvent[]
  iftaTrips            IftaTrip[]
  driverSettlements    DriverSettlement[]
  routeTotalMiles      Float?
  routeStateMiles      Json?
  routePolyline        String?
  routeComputedAt      DateTime?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt

  @@unique([companyId, loadNumber])
  @@index([companyId])
}

model LoadCommodityLine {
  id          String @id @default(cuid())
  loadId      String
  load        Load   @relation(fields: [loadId], references: [id], onDelete: Cascade)
  sequence    Int
  quantity    Float  @default(1)
  description String
  weightLbs   Int
  pieces      String?
  lengthIn    Float?
  widthIn     Float?
  heightIn    Float?

  @@index([loadId])
}

model LoadStop {
  id            String    @id @default(cuid())
  loadId        String
  load          Load      @relation(fields: [loadId], references: [id], onDelete: Cascade)
  facilityId    String?
  facility      Facility? @relation(fields: [facilityId], references: [id])
  type          String
  sequence      Int
  facilityName  String
  address       String?
  city          String
  state         String
  postalCode    String?
  appointmentAt DateTime?
  actualAt      DateTime?
  instructions  String?
  latitude      Float?
  longitude     Float?
  geocodedAt    DateTime?
}

model LoadCharge {
  id             String              @id @default(cuid())
  loadId         String
  load           Load                @relation(fields: [loadId], references: [id], onDelete: Cascade)
  lineTypeId     String?
  lineType       CustomerChargeType? @relation(fields: [lineTypeId], references: [id], onDelete: SetNull)
  label          String
  chargeType     String              @default("Linehaul")
  description    String?
  unitRateCents  Int                 @default(0)
  quantity       Float               @default(1)
  amountCents    Int
  sortOrder      Int                 @default(0)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  @@index([loadId])
  @@index([lineTypeId])
}

model LoadExpense {
  id          String   @id @default(cuid())
  loadId      String
  load        Load     @relation(fields: [loadId], references: [id], onDelete: Cascade)
  label       String
  expenseType String   @default("Other")
  amountCents Int
}

model CommissionProfile {
  id        String                  @id @default(cuid())
  companyId String
  company   Company                 @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name      String
  isDefault Boolean                 @default(false)
  rule      CommissionProfileRule?
  branches  Branch[]
  loads     Load[]
  commissions LoadCommission[]
  createdAt DateTime                @default(now())
  updatedAt DateTime                @updatedAt

  @@index([companyId])
}

model CommissionProfileRule {
  id                          String            @id @default(cuid())
  profileId                   String            @unique
  profile                     CommissionProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  branchSharePercent          Int               @default(60)
  companySharePercent         Int               @default(40)
  companyMinimumExpensePercent Int              @default(10)
}

model LoadCommission {
  id                 String            @id @default(cuid())
  loadId             String            @unique
  load               Load              @relation(fields: [loadId], references: [id], onDelete: Cascade)
  branchId           String?
  branch             Branch?           @relation(fields: [branchId], references: [id])
  profileId          String?
  profile            CommissionProfile? @relation(fields: [profileId], references: [id])
  profileName        String
  isCommissionable   Boolean           @default(true)
  revenueCents       Int               @default(0)
  grossExpenseCents  Int               @default(0)
  grossProfitCents   Int               @default(0)
  branchShareCents   Int               @default(0)
  companyShareCents  Int               @default(0)
  calculationMethod  String            @default("STANDARD_SPLIT")
  status             String            @default("PENDING")
  payableAt          DateTime?
  settledAt          DateTime?
  settledByUserId    String?
  settledByUser      User?             @relation(fields: [settledByUserId], references: [id])
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  @@index([branchId])
  @@index([status])
}

model DispatchAssignment {
  id             String           @id @default(cuid())
  loadId         String
  load           Load             @relation(fields: [loadId], references: [id], onDelete: Cascade)
  /// 0 = primary assignment (fleet lives here); higher = additional carriers
  sequence       Int              @default(0)
  /// Optional when covering with own fleet (Premium + Trucking)
  carrierId      String?
  carrier        Carrier?         @relation(fields: [carrierId], references: [id])
  driverId       String?
  driver         Driver?          @relation(fields: [driverId], references: [id], onDelete: SetNull)
  truckId        String?
  truck          Truck?           @relation(fields: [truckId], references: [id], onDelete: SetNull)
  trailerId      String?
  trailer        Trailer?         @relation(fields: [trailerId], references: [id], onDelete: SetNull)
  /// Denormalized snapshots for PDFs / historical rate cons
  driverName     String?
  driverPhone    String?
  truckNumber    String?
  trailerNumber  String?
  /// Free-form leg origin/destination (additional carriers); blank on primary falls back to load stops
  originFacilityName      String?
  originCity              String?
  originState             String?
  originPostalCode        String?
  destinationFacilityName String?
  destinationCity         String?
  destinationState        String?
  destinationPostalCode   String?
  rateCents      Int              @default(0)
  assignedAt     DateTime         @default(now())
  checkCalls     CheckCall[]
  payLines       CarrierPayLine[]
  rateConfirmations LoadDocument[]

  @@index([loadId])
  @@unique([loadId, sequence])
  @@index([carrierId])
  @@index([driverId])
  @@index([truckId])
  @@index([trailerId])
}

model CarrierPayLine {
  id             String              @id @default(cuid())
  loadId         String
  load           Load                @relation(fields: [loadId], references: [id], onDelete: Cascade)
  assignmentId   String?
  assignment     DispatchAssignment? @relation(fields: [assignmentId], references: [id], onDelete: SetNull)
  lineTypeId     String
  lineType       CarrierPayLineType  @relation(fields: [lineTypeId], references: [id])
  description    String?
  unitRateCents  Int                 @default(0)
  quantity       Float               @default(1)
  amountCents    Int                 @default(0)
  sortOrder      Int                 @default(0)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  @@index([loadId])
  @@index([assignmentId])
  @@index([lineTypeId])
}

model CheckCall {
  id             String             @id @default(cuid())
  assignmentId   String
  assignment     DispatchAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  location       String
  status         String
  notes          String?
  occurredAt     DateTime           @default(now())
  nextCheckAt    DateTime?
  nextCheckNotes String?
  latitude       Float?
  longitude      Float?
  geocodedAt     DateTime?
}

model LoadDocument {
  id                String    @id @default(cuid())
  companyId         String
  company           Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  loadId            String?
  load              Load?     @relation(fields: [loadId], references: [id], onDelete: Cascade)
  customerId        String?
  customer          Customer? @relation(fields: [customerId], references: [id])
  carrierId         String?
  carrier           Carrier?  @relation(fields: [carrierId], references: [id])
  /// Rate confirmation (and similar) can be scoped to a specific carrier assignment
  assignmentId      String?
  assignment        DispatchAssignment? @relation(fields: [assignmentId], references: [id], onDelete: SetNull)
  uploadedById      String?
  uploadedBy        User?     @relation(fields: [uploadedById], references: [id])
  type              String
  types             String?
  name              String
  documentNumber    String?
  filePath          String?
  originalFileName  String?
  mimeType          String?
  fileSizeBytes     Int?
  notes             String?
  status            String    @default("PROCESSED")
  isCompanyDocument Boolean   @default(false)
  generatedContent  String?
  generatedAt       DateTime?
  uploadedAt        DateTime  @default(now())
  updatedAt         DateTime  @default(now()) @updatedAt
  emailThreads      EmailThread[]

  @@index([companyId])
  @@index([loadId])
  @@index([customerId])
  @@index([carrierId])
  @@index([assignmentId])
}

model LoadNote {
  id        String   @id @default(cuid())
  loadId    String
  load      Load     @relation(fields: [loadId], references: [id], onDelete: Cascade)
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  body      String
  /// When true, note stays internal (never on docs, emails, or reports).
  isPrivate Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([loadId, isPrivate])
}

model LoadActivity {
  id        String   @id @default(cuid())
  loadId    String
  load      Load     @relation(fields: [loadId], references: [id], onDelete: Cascade)
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  action    String
  details   String?
  createdAt DateTime @default(now())
}

model Invoice {
  id            String               @id @default(cuid())
  companyId     String
  company       Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  invoiceNo     String
  loadId        String
  load          Load                 @relation(fields: [loadId], references: [id])
  customerId    String
  customer      Customer             @relation(fields: [customerId], references: [id])
  status        String               @default("DRAFT")
  totalCents    Int
  balanceCents  Int                  @default(0)
  issuedAt      DateTime?
  dueAt         DateTime?
  paidAt        DateTime?
  externalQboId String?
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  emailThreads  EmailThread[]
  applications  PaymentApplication[]

  @@unique([companyId, invoiceNo])
  @@index([companyId])
  @@index([companyId, status])
  @@index([companyId, dueAt])
}

model CarrierBill {
  id                 String               @id @default(cuid())
  companyId          String
  company            Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  billNo             String
  loadId             String
  load               Load                 @relation(fields: [loadId], references: [id])
  carrierId          String
  carrier            Carrier              @relation(fields: [carrierId], references: [id])
  status             String               @default("DRAFT")
  totalCents         Int
  balanceCents       Int                  @default(0)
  /// Snapshot of payee at bill creation (factor or carrier)
  payeeName          String?
  nameOnCheck        String?
  remitAddress       String?
  billReference      String?
  paymentTermsDays   Int?
  paymentMethod      String?
  notes              String?
  factoringCompanyId String?
  factoringCompany   FactoringCompany?    @relation(fields: [factoringCompanyId], references: [id], onDelete: SetNull)
  receivedAt         DateTime?
  dueAt              DateTime?
  paidAt             DateTime?
  externalQboId      String?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  applications       PaymentApplication[]

  @@unique([companyId, billNo])
  @@index([companyId])
  @@index([companyId, status])
  @@index([companyId, dueAt])
  @@index([factoringCompanyId])
}

/// AR (customer) or AP (carrier/factor) cash receipt / disbursement
model Payment {
  id                 String               @id @default(cuid())
  companyId          String
  company            Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  /// AR | AP
  direction          String
  amountCents        Int
  paidAt             DateTime             @default(now())
  method             String               @default("CHECK")
  reference          String?
  notes              String?
  customerId         String?
  customer           Customer?            @relation(fields: [customerId], references: [id], onDelete: SetNull)
  carrierId          String?
  carrier            Carrier?             @relation(fields: [carrierId], references: [id], onDelete: SetNull)
  factoringCompanyId String?
  factoringCompany   FactoringCompany?    @relation(fields: [factoringCompanyId], references: [id], onDelete: SetNull)
  createdByUserId    String?
  applications       PaymentApplication[]
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt

  @@index([companyId])
  @@index([companyId, direction])
  @@index([customerId])
  @@index([carrierId])
}

model PaymentApplication {
  id            String       @id @default(cuid())
  paymentId     String
  payment       Payment      @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  invoiceId     String?
  invoice       Invoice?     @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  carrierBillId String?
  carrierBill   CarrierBill? @relation(fields: [carrierBillId], references: [id], onDelete: Cascade)
  amountCents   Int
  createdAt     DateTime     @default(now())

  @@index([paymentId])
  @@index([invoiceId])
  @@index([carrierBillId])
}

model IntegrationAccount {
  id               String    @id @default(cuid())
  companyId        String
  company          Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  provider         String
  displayName      String
  status           String    @default("Not Connected")
  apiKeyLast4      String?
  notes            String?
  realmId          String?
  accessTokenEnc   String?
  refreshTokenEnc  String?
  tokenExpiresAt   DateTime?
  connectedAt      DateTime?
  lastSyncAt       DateTime?
  lastError        String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([companyId])
  @@unique([companyId, provider])
}

/// Per-method export history for invoices and carrier bills (ONLINE vs IIF are independent).
model AccountingExport {
  id               String    @id @default(cuid())
  companyId        String
  company          Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  entityType       String
  entityId         String
  method           String
  status           String    @default("SYNCED")
  exportedAt       DateTime?
  externalId       String?
  message          String?
  exportedByUserId String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@unique([entityType, entityId, method])
  @@index([companyId, method])
  @@index([companyId, entityType, entityId])
}

/// Durable background jobs (PDF generation, mailbox sync, etc.).
model BackgroundJob {
  id          String    @id @default(cuid())
  type        String
  payloadJson String
  status      String    @default("PENDING")
  attempts    Int       @default(0)
  maxAttempts Int       @default(5)
  availableAt DateTime  @default(now())
  lockedAt    DateTime?
  lockedBy    String?
  lastError   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  completedAt DateTime?

  @@index([status, availableAt])
  @@index([type, status])
}

// --- Premium + Trucking fleet models ---

model Driver {
  id                String                     @id @default(cuid())
  companyId         String
  company           Company                    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  firstName         String
  lastName          String
  phone             String?
  email             String?
  employeeNumber    String?
  /// ACTIVE | INACTIVE | TERMINATED
  status            String                     @default("ACTIVE")
  hireDate          DateTime?
  terminationDate   DateTime?
  dateOfBirth       DateTime?
  cdlNumber         String?
  cdlClass          String?
  cdlState          String?
  cdlEndorsements   String?
  cdlExpiresAt      DateTime?
  medicalExpiresAt  DateTime?
  notes             String?
  /// CSA BASIC percentile scores (0-100, higher = worse typically); optional Phase 2 fields
  csaUnsafeDriving  Float?
  csaHosCompliance  Float?
  csaVehicleMaint   Float?
  csaControlledSub  Float?
  csaDriverFitness  Float?
  csaCrashIndicator Float?
  /// Last imported HOS / ELD summary snapshot (free text or JSON)
  hosStatusSummary  String?
  hosLastSyncedAt   DateTime?
  qualificationItems DriverQualificationItem[]
  assignments       DispatchAssignment[]
  safetyEvents      SafetyEvent[]
  dvirReports       DvirReport[]
  settlements       DriverSettlement[]
  iftaTrips         IftaTrip[]
  createdAt         DateTime                   @default(now())
  updatedAt         DateTime                   @updatedAt

  @@index([companyId])
  @@index([companyId, status])
  @@unique([companyId, employeeNumber])
}

model Truck {
  id                         String                     @id @default(cuid())
  companyId                  String
  company                    Company                    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  unitNumber                 String
  year                       Int?
  make                       String?
  model                      String?
  vin                        String?
  licensePlate               String?
  licenseState               String?
  /// ACTIVE | INACTIVE | OUT_OF_SERVICE | SHOP
  status                     String                     @default("ACTIVE")
  /// COMPANY | OWNER_OPERATOR
  ownership                  String                     @default("COMPANY")
  registrationExpiresAt      DateTime?
  annualInspectionExpiresAt  DateTime?
  irpExpiresAt               DateTime?
  insuranceExpiresAt         DateTime?
  notes                      String?
  /// External ELD asset id when linked
  eldAssetId                 String?
  eldProvider                String?
  eldLastLocation            String?
  eldLastPingAt              DateTime?
  assignments                DispatchAssignment[]
  safetyEvents               SafetyEvent[]
  dvirReports                DvirReport[]
  iftaTrips                  IftaTrip[]
  createdAt                  DateTime                   @default(now())
  updatedAt                  DateTime                   @updatedAt

  @@index([companyId])
  @@index([companyId, status])
  @@unique([companyId, unitNumber])
}

model Trailer {
  id                         String                     @id @default(cuid())
  companyId                  String
  company                    Company                    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  unitNumber                 String
  year                       Int?
  make                       String?
  model                      String?
  vin                        String?
  licensePlate               String?
  licenseState               String?
  /// Dry Van | Reefer | Flatbed | Step Deck | etc.
  trailerType                String                     @default("Dry Van")
  /// ACTIVE | INACTIVE | OUT_OF_SERVICE | SHOP
  status                     String                     @default("ACTIVE")
  registrationExpiresAt      DateTime?
  annualInspectionExpiresAt  DateTime?
  insuranceExpiresAt         DateTime?
  notes                      String?
  assignments                DispatchAssignment[]
  safetyEvents               SafetyEvent[]
  dvirReports                DvirReport[]
  createdAt                  DateTime                   @default(now())
  updatedAt                  DateTime                   @updatedAt

  @@index([companyId])
  @@index([companyId, status])
  @@unique([companyId, unitNumber])
}

model EquipmentMaintenanceLog {
  id          String   @id @default(cuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  /// TRUCK | TRAILER
  assetType   String
  assetId     String
  performedAt DateTime @default(now())
  /// PM | REPAIR | INSPECTION | OTHER
  workType    String   @default("PM")
  odometer    Int?
  costCents   Int      @default(0)
  vendor      String?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([companyId])
  @@index([companyId, assetType, assetId])
}

model DriverQualificationItem {
  id               String    @id @default(cuid())
  driverId         String
  driver           Driver    @relation(fields: [driverId], references: [id], onDelete: Cascade)
  /// APPLICATION | MVR | ROAD_TEST | MEDICAL_CARD | CDL_COPY | CLEARINGHOUSE | PRIOR_EMPLOYER | ANNUAL_VIOLATIONS | TRAINING | OTHER
  category         String
  title            String
  issuedAt         DateTime?
  expiresAt        DateTime?
  /// CURRENT | EXPIRED | MISSING | PENDING
  status           String    @default("PENDING")
  notes            String?
  filePath         String?
  originalFileName String?
  mimeType         String?
  fileSizeBytes    Int?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([driverId])
  @@index([driverId, category])
}

model SafetyEvent {
  id              String    @id @default(cuid())
  companyId       String
  company         Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  driverId        String?
  driver          Driver?   @relation(fields: [driverId], references: [id], onDelete: SetNull)
  truckId         String?
  truck           Truck?    @relation(fields: [truckId], references: [id], onDelete: SetNull)
  trailerId       String?
  trailer         Trailer?  @relation(fields: [trailerId], references: [id], onDelete: SetNull)
  loadId          String?
  load            Load?     @relation(fields: [loadId], references: [id], onDelete: SetNull)
  /// ACCIDENT | INCIDENT | ROADSIDE | VIOLATION | OTHER
  eventType       String    @default("ACCIDENT")
  occurredAt      DateTime  @default(now())
  severity        String?
  location        String?
  description     String
  dotRecordable   Boolean   @default(false)
  claimNumber     String?
  resolutionNotes String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([companyId])
  @@index([companyId, occurredAt])
  @@index([driverId])
}

model IftaQuarter {
  id            String          @id @default(cuid())
  companyId     String
  company       Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  year          Int
  /// 1 | 2 | 3 | 4
  quarter       Int
  /// OPEN | IN_PROGRESS | FILED
  status        String          @default("OPEN")
  notes         String?
  filedAt       DateTime?
  trips         IftaTrip[]
  fuelPurchases IftaFuelPurchase[]
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@unique([companyId, year, quarter])
  @@index([companyId])
}

model IftaTrip {
  id          String      @id @default(cuid())
  quarterId   String
  quarter     IftaQuarter @relation(fields: [quarterId], references: [id], onDelete: Cascade)
  truckId     String?
  truck       Truck?      @relation(fields: [truckId], references: [id], onDelete: SetNull)
  driverId    String?
  driver      Driver?     @relation(fields: [driverId], references: [id], onDelete: SetNull)
  loadId      String?
  load        Load?       @relation(fields: [loadId], references: [id], onDelete: SetNull)
  startAt     DateTime
  endAt       DateTime?
  /// Two-letter jurisdiction (state/province), e.g. TX
  jurisdiction String
  miles       Float       @default(0)
  notes       String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([quarterId])
  @@index([quarterId, jurisdiction])
  @@index([truckId])
}

model IftaFuelPurchase {
  id           String      @id @default(cuid())
  quarterId    String
  quarter      IftaQuarter @relation(fields: [quarterId], references: [id], onDelete: Cascade)
  purchasedAt  DateTime
  jurisdiction String
  gallons      Float       @default(0)
  costCents    Int         @default(0)
  vendor       String?
  truckId      String?
  notes        String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@index([quarterId])
  @@index([quarterId, jurisdiction])
}

model DvirReport {
  id            String    @id @default(cuid())
  companyId     String
  company       Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  driverId      String?
  driver        Driver?   @relation(fields: [driverId], references: [id], onDelete: SetNull)
  truckId       String?
  truck         Truck?    @relation(fields: [truckId], references: [id], onDelete: SetNull)
  trailerId     String?
  trailer       Trailer?  @relation(fields: [trailerId], references: [id], onDelete: SetNull)
  inspectedAt   DateTime  @default(now())
  /// PRE_TRIP | POST_TRIP | OTHER
  inspectionType String   @default("PRE_TRIP")
  /// SATISFACTORY | DEFECTS_CORRECTED | UNSATISFACTORY
  result        String    @default("SATISFACTORY")
  odometer      Int?
  defectsJson   String?
  remarks       String?
  certifiedSafe Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([companyId])
  @@index([companyId, inspectedAt])
  @@index([truckId])
  @@index([driverId])
}

model DriverSettlement {
  id              String    @id @default(cuid())
  companyId       String
  company         Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  driverId        String
  driver          Driver    @relation(fields: [driverId], references: [id], onDelete: Cascade)
  loadId          String?
  load            Load?     @relation(fields: [loadId], references: [id], onDelete: SetNull)
  periodStart     DateTime?
  periodEnd       DateTime?
  /// FLAT | PER_MILE | PERCENT_REVENUE | OTHER
  payMethod       String    @default("FLAT")
  miles           Float     @default(0)
  revenueCents    Int       @default(0)
  payCents        Int       @default(0)
  deductionsCents Int       @default(0)
  netCents        Int       @default(0)
  /// DRAFT | APPROVED | PAID | VOID
  status          String    @default("DRAFT")
  paidAt          DateTime?
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([companyId])
  @@index([companyId, status])
  @@index([driverId])
  @@index([loadId])
}
